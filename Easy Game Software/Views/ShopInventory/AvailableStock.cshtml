@model List<Easy_Games_Software.Models.StockItem>
@{
    ViewData["Title"] = "Available Stock for Transfer";
}

<h1><i class="bi bi-box-arrow-down"></i> Transfer Stock to Shop</h1>
<p class="lead">Shop: <strong>@ViewData["ShopName"]</strong></p>

<div class="row mb-3">
    <div class="col-md-8">
        <form method="get" class="d-flex">
            <input type="text" name="search" class="form-control me-2"
                   placeholder="Search items..." value="@ViewData["SearchTerm"]" />
            <select name="category" class="form-select me-2" style="width: auto;">
                <option value="">All Categories</option>
                @if (ViewData["Categories"] != null)
                {
                    var categories = ViewData["Categories"] as Easy_Games_Software.Models.StockCategory[];
                    if (categories != null)
                    {
                        foreach (var cat in categories)
                        {
                            var selected = ViewData["SelectedCategory"]?.ToString() == cat.ToString() ? "selected" : "";
                            <option value="@cat" selected="@selected">@cat</option>
                        }
                    }
                }
            </select>
            <button type="submit" class="btn btn-primary">Search</button>
        </form>
    </div>
    <div class="col-md-4 text-end">
        <a asp-action="Dashboard" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No items available for transfer.
    </div>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Available in Owner Inventory</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@item.Name</strong><br />
                                    <small class="text-muted">@item.Description</small>
                                </td>
                                <td><span class="badge bg-secondary">@item.Category</span></td>
                                <td>$@item.Price.ToString("F2")</td>
                                <td>
                                    @if (item.Quantity == 0)
                                    {
                                        <span class="text-danger fw-bold">@item.Quantity</span>
                                    }
                                    else if (item.Quantity <= 5)
                                    {
                                        <span class="text-warning fw-bold">@item.Quantity</span>
                                    }
                                    else
                                    {
                                        <span class="text-success fw-bold">@item.Quantity</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Quantity > 0)
                                    {
                                        <a asp-action="Transfer" asp-route-stockItemId="@item.Id"
                                           class="btn btn-sm btn-primary">
                                            <i class="bi bi-arrow-right-circle"></i> Transfer
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Out of Stock</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-3">
                <p class="text-muted">
                    <i class="bi bi-info-circle"></i>
                    Transferring items will move them from the main owner inventory to your shop's inventory.
                </p>
            </div>
        </div>
    </div>
}