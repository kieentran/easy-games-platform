@model Easy_Games_Software.Models.Shop
@{
    ViewData["Title"] = "Shop Dashboard";
    var stats = ViewData["Statistics"] as Dictionary<string, object>;
}

<h1><i class="bi bi-speedometer2"></i> Shop Dashboard</h1>
<p class="lead">@Model.ShopName - @Model.Location</p>

<div class="row mb-4">
    <!-- Quick Actions -->
    <div class="col-md-12">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-lightning"></i> Quick Actions</h5>
                <div class="btn-group" role="group">
                    <a asp-action="Index" asp-controller="PointOfSale" class="btn btn-light btn-lg">
                        <i class="bi bi-cash-register"></i> Open POS
                    </a>
                    <a asp-action="AvailableStock" class="btn btn-light btn-lg">
                        <i class="bi bi-box-arrow-down"></i> Transfer Stock
                    </a>
                    <a asp-action="ViewShopStock" class="btn btn-light btn-lg">
                        <i class="bi bi-boxes"></i> View Inventory
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@if (stats != null)
{
    <div class="row mb-4">
        <!-- Statistics Cards -->
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h2 class="text-primary">@stats["TotalItems"]</h2>
                    <p class="text-muted mb-0">Total Items in Stock</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h2 class="text-success">$@(((decimal)stats["TotalValue"]).ToString("F2"))</h2>
                    <p class="text-muted mb-0">Inventory Value</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h2 class="text-warning">@stats["LowStockItems"]</h2>
                    <p class="text-muted mb-0">Low Stock Alerts</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h2 class="text-info">@stats["TotalTransactions"]</h2>
                    <p class="text-muted mb-0">Total Sales</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-currency-dollar"></i> Sales Performance</h5>
                </div>
                <div class="card-body">
                    <h3 class="text-success">$@(((decimal)stats["TotalSales"]).ToString("F2"))</h3>
                    <p class="text-muted">Total Sales Revenue</p>
                    <p class="mb-0">
                        <strong>@stats["TotalTransactions"]</strong> transactions completed
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Inventory Alerts</h5>
                </div>
                <div class="card-body">
                    <p><strong>@stats["LowStockItems"]</strong> items need restocking</p>
                    <p><strong>@stats["OutOfStockItems"]</strong> items out of stock</p>
                    @if ((int)stats["LowStockItems"] > 0 || (int)stats["OutOfStockItems"] > 0)
                    {
                        <a asp-action="AvailableStock" class="btn btn-warning">
                            <i class="bi bi-box-arrow-down"></i> Transfer Stock Now
                        </a>
                    }
                    else
                    {
                        <p class="text-success mb-0">
                            <i class="bi bi-check-circle"></i> All items well stocked!
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>
}