@model List<Easy_Games_Software.Models.StockItem>
@{
    ViewData["Title"] = "Best Sellers";
    var discountRate = ViewData["DiscountRate"] as decimal? ?? 0;
    var userTier = ViewData["UserTier"] as Easy_Games_Software.Models.UserTier?;
}

<div class="row mb-4">
    <div class="col-md-12">
        <h1><i class="bi bi-trophy"></i> Best Sellers</h1>
        <p class="lead">Our most popular products based on sales</p>
        @if (userTier == Easy_Games_Software.Models.UserTier.Gold)
        {
            <div class="alert alert-warning">
                <i class="bi bi-star-fill"></i> <strong>Gold Member:</strong> You get 10% off all purchases!
            </div>
        }
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No sales data available yet.
    </div>
}
else
{
    <div class="row">
        @{
            int rank = 1;
        }
        @foreach (var item in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="row g-0">
                        <div class="col-md-4">
                            <div class="text-center p-3 bg-light h-100 d-flex align-items-center justify-content-center">
                                <div>
                                    <div class="badge bg-primary fs-3 rounded-circle p-3 mb-2">
                                        #@rank
                                    </div>
                                    <br />
                                    <i class="bi bi-controller" style="font-size: 50px; color: #ccc;"></i>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="card-body">
                                <h5 class="card-title">@item.Name</h5>
                                <p class="text-muted small">
                                    <span class="badge bg-secondary">@item.Category</span>
                                    <span class="badge bg-info text-dark ms-2">@item.UnitsSold sold</span>
                                </p>
                                <p class="card-text small">@item.Description</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        @if (discountRate > 0)
                                        {
                                            <span class="text-decoration-line-through text-muted">$@item.Price.ToString("F2")</span>
                                            <span class="h5 text-danger ms-2">$@((item.Price * (1 - discountRate)).ToString("F2"))</span>
                                        }
                                        else
                                        {
                                            <span class="h5">$@item.Price.ToString("F2")</span>
                                        }
                                    </div>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary">
                                        View Details
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            rank++;
        }
    </div>
}