@model List<Easy_Games_Software.Models.StockItem>
@{
    ViewData["Title"] = "Store";
    var discountRate = ViewData["DiscountRate"] as decimal? ?? 0;
    var userTier = ViewData["UserTier"] as Easy_Games_Software.Models.UserTier?;
}

<div class="row mb-4">
    <div class="col-md-8">
        <h1><i class="bi bi-shop"></i> Game Store</h1>
        @if (userTier == Easy_Games_Software.Models.UserTier.Gold)
        {
            <div class="alert alert-warning">
                <i class="bi bi-star-fill"></i> <strong>Gold Member:</strong> You get 10% off all purchases!
            </div>
        }
    </div>
    <div class="col-md-4">
        <form method="get" asp-action="Index" class="d-flex">
            <input type="text" name="search" class="form-control me-2"
                   placeholder="Search products..." value="@ViewData["SearchTerm"]" />
            <button type="submit" class="btn btn-outline-primary">
                <i class="bi bi-search"></i>
            </button>
        </form>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-6">
        <div class="btn-group" role="group">
            <a asp-action="Index" class="btn btn-outline-secondary @(ViewData["SelectedCategory"] == null ? "active" : "")">
                All
            </a>
            @if (ViewData["Categories"] != null)
            {
                @foreach (var category in (Easy_Games_Software.Models.StockCategory[])ViewData["Categories"])
                {
                    <a asp-action="Index" asp-route-category="@category"
                       class="btn btn-outline-secondary @(ViewData["SelectedCategory"]?.ToString() == category.ToString() ? "active" : "")">
                        @category
                    </a>
                }
            }
        </div>
    </div>
    <div class="col-md-6 text-end">
        <div class="dropdown">
            <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                <i class="bi bi-sort-down"></i> Sort by
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" asp-action="Index" asp-route-sort="name">Name</a></li>
                <li><a class="dropdown-item" asp-action="Index" asp-route-sort="price-asc">Price: Low to High</a></li>
                <li><a class="dropdown-item" asp-action="Index" asp-route-sort="price-desc">Price: High to Low</a></li>
                <li><a class="dropdown-item" asp-action="Index" asp-route-sort="rating">Rating</a></li>
                <li><a class="dropdown-item" asp-action="Index" asp-route-sort="newest">Newest</a></li>
            </ul>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No products found.
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 col-sm-6 mb-4">
                <div class="card h-100 shadow-sm">
                    @if (item.IsFeatured)
                    {
                        <div class="badge bg-danger position-absolute" style="top: 10px; right: 10px; z-index: 1;">
                            FEATURED
                        </div>
                    }
                    <div class="card-img-top text-center p-3 bg-light" style="height: 200px;">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.Name" style="max-height: 100%; max-width: 100%;" />
                        }
                        else
                        {
                            <i class="bi bi-controller" style="font-size: 100px; color: #ccc;"></i>
                        }
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@item.Name</h5>
                        <p class="text-muted small">
                            <span class="badge bg-secondary">@item.Category</span>
                            @if (item.Rating > 0)
                            {
                                <span class="ms-2">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= Math.Round(item.Rating))
                                        {
                                            <i class="bi bi-star-fill text-warning"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star text-warning"></i>
                                        }
                                    }
                                    <small>(@item.Rating.ToString("F1"))</small>
                                </span>
                            }
                        </p>
                        <p class="card-text small">@item.Description</p>
                        <div class="mt-auto">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div>
                                    @if (discountRate > 0)
                                    {
                                        <span class="text-decoration-line-through text-muted">$@item.Price.ToString("F2")</span>
                                        <span class="h5 text-danger ms-2">$@((item.Price * (1 - discountRate)).ToString("F2"))</span>
                                    }
                                    else
                                    {
                                        <span class="h5">$@item.Price.ToString("F2")</span>
                                    }
                                </div>
                                <div>
                                    @if (item.IsInStock())
                                    {
                                        <span class="badge bg-success">In Stock (@item.Quantity)</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Out of Stock</span>
                                    }
                                </div>
                            </div>
                            <div class="btn-group w-100" role="group">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                @if (User.Identity != null && User.Identity.IsAuthenticated && item.IsInStock())
                                {
                                    <form asp-controller="Cart" asp-action="Add" method="post" class="flex-fill">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="itemId" value="@item.Id" />
                                        <input type="hidden" name="quantity" value="1" />
                                        <button type="submit" class="btn btn-primary w-100">
                                            <i class="bi bi-cart-plus"></i> Add to Cart
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}