@* Claude Prompt 007 start *@
@model List<Easy_Games_Software.Models.StockItem>
@{
    ViewData["Title"] = "Manage Stock";
}

<h1><i class="bi bi-box-seam"></i> Manage Stock</h1>

<div class="row mb-3">
    <div class="col-md-8">
        <form method="get" class="d-flex">
            <input type="text" name="search" class="form-control me-2" 
                   placeholder="Search stock..." value="@ViewData["SearchTerm"]" />
            <select name="category" class="form-select me-2" style="width: auto;">
                <option value="">All Categories</option>
                @if (ViewData["Categories"] != null)
                {
                    var categories = ViewData["Categories"] as Easy_Games_Software.Models.StockCategory[];
                    if (categories != null)
                    {
                        @foreach (var cat in categories)
                        {
                            var selected = ViewData["SelectedCategory"]?.ToString() == cat.ToString() ? "selected" : "";
                            <option value="@cat" selected="@selected">@cat</option>
                        }
                    }
                }
            </select>
            <button type="submit" class="btn btn-primary">Search</button>
        </form>
    </div>
    <div class="col-md-4 text-end">
        <a asp-action="CreateStock" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Add New Stock
        </a>
        <a asp-action="ImportStock" class="btn btn-info ms-2">
            <i class="bi bi-upload"></i> Import CSV
        </a>
    </div>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No stock items found. 
        <a asp-action="CreateStock">Add your first item</a> or 
        <a asp-action="ImportStock">import from CSV</a>.
    </div>
}
else
{
    <div class="card">
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Units Sold</th>
                        <th>Rating</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>
                                @item.Name
                                @if (item.IsFeatured)
                                {
                                    <span class="badge bg-danger ms-2">Featured</span>
                                }
                            </td>
                            <td><span class="badge bg-secondary">@item.Category</span></td>
                            <td>$@item.Price.ToString("F2")</td>
                            <td>
                                @if (item.Quantity <= 5 && item.Quantity > 0)
                                {
                                    <span class="text-warning">@item.Quantity</span>
                                }
                                else if (item.Quantity == 0)
                                {
                                    <span class="text-danger">@item.Quantity</span>
                                }
                                else
                                {
                                    <span>@item.Quantity</span>
                                }
                            </td>
                            <td>@item.UnitsSold</td>
                            <td>
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= Math.Round(item.Rating))
                                    {
                                        <i class="bi bi-star-fill text-warning"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star text-warning"></i>
                                    }
                                }
                                <small>(@item.Rating.ToString("F1"))</small>
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-action="EditStock" asp-route-id="@item.Id" 
                                       class="btn btn-primary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="DeleteStock" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-danger" 
                                                title="Delete"
                                                onclick="return confirm('Are you sure you want to delete @item.Name?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            
            <div class="mt-3">
                <strong>Total Items:</strong> @Model.Count | 
                <strong>Total Value:</strong> $@Model.Sum(x => x.Price * x.Quantity).ToString("F2") |
                <strong>Total Units Sold:</strong> @Model.Sum(x => x.UnitsSold)
            </div>
        </div>
    </div>
}
@* Claude Prompt 007 end *@