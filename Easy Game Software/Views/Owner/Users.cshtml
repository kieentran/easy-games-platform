@* Claude Prompt 010 start *@
@model List<Easy_Games_Software.Models.User>
@{
    ViewData["Title"] = "Manage Users";
}

<h1><i class="bi bi-people"></i> Manage Users</h1>

<div class="row mb-3">
    <div class="col-md-8">
        <form method="get" class="d-flex">
            <input type="text" name="search" class="form-control me-2"
                   placeholder="Search users..." value="@ViewData["SearchTerm"]" />
            <select name="role" class="form-select me-2" style="width: auto;">
                <option value="">All Roles</option>
                <option value="User" selected="@(ViewData["SelectedRole"]?.ToString() == "User")">User</option>
                <option value="Owner" selected="@(ViewData["SelectedRole"]?.ToString() == "Owner")">Owner</option>
            </select>
            <button type="submit" class="btn btn-primary">Search</button>
        </form>
    </div>
    <div class="col-md-4 text-end">
        <a asp-action="SendEmail" class="btn btn-success">
            <i class="bi bi-envelope"></i> Send Email to Customers
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <table class="table">
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Full Name</th>
                    <th>Role</th>
                    <th>Tier</th>
                    <th>Points</th>
                    <th>Total Spent</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Username</td>
                        <td>@(user.Email ?? "N/A")</td>
                        <td>@(user.FullName ?? "N/A")</td>
                        <td>
                            <span class="badge @(user.Role == Easy_Games_Software.Models.UserRole.Owner ? "bg-danger" : "bg-primary")">
                                @user.Role
                            </span>
                        </td>
                        <td>
                            @{
                                var tierBadgeClass = user.Tier switch
                                {
                                    Easy_Games_Software.Models.UserTier.Bronze => "bg-secondary",
                                    Easy_Games_Software.Models.UserTier.Silver => "bg-light text-dark",
                                    Easy_Games_Software.Models.UserTier.Gold => "bg-warning text-dark",
                                    Easy_Games_Software.Models.UserTier.Platinum => "bg-info text-dark",
                                    _ => "bg-secondary"
                                };
                                var tierIcon = user.Tier switch
                                {
                                    Easy_Games_Software.Models.UserTier.Bronze => "🥉",
                                    Easy_Games_Software.Models.UserTier.Silver => "🥈",
                                    Easy_Games_Software.Models.UserTier.Gold => "🥇",
                                    Easy_Games_Software.Models.UserTier.Platinum => "💎",
                                    _ => ""
                                };
                            }
                            <span class="badge @tierBadgeClass">
                                @tierIcon @user.Tier
                            </span>
                        </td>
                        <td>@user.Points</td>
                        <td>$@user.TotalSpent.ToString("F2")</td>
                        <td>
                            <a asp-action="UserDetails" asp-route-id="@user.Id" class="btn btn-sm btn-info" title="View Details">
                                <i class="bi bi-eye"></i>
                            </a>

                            @if (!string.IsNullOrEmpty(user.Email))
                            {
                                <button type="button" class="btn btn-sm btn-warning" title="Send Email"
                                        data-bs-toggle="modal" data-bs-target="#emailModal"
                                        data-user-id="@user.Id"
                                        data-user-name="@user.Username"
                                        data-user-email="@user.Email">
                                    <i class="bi bi-envelope"></i>
                                </button>
                            }

                            @if (user.Role != Easy_Games_Software.Models.UserRole.Owner)
                            {
                                <form asp-action="PromoteUser" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm btn-success" title="Promote to Owner">
                                        <i class="bi bi-arrow-up"></i>
                                    </button>
                                </form>
                            }

                            <form asp-action="DeleteUser" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@user.Id" />
                                <button type="submit" class="btn btn-sm btn-danger" title="Delete User"
                                        onclick="return confirm('Delete this user?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Email Modal -->
<div class="modal fade" id="emailModal" tabindex="-1" aria-labelledby="emailModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="SendEmailToUser" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="emailModalLabel">
                        <i class="bi bi-envelope"></i> Send Email to <span id="modalUserName"></span>
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="userId" id="modalUserId" />

                    <div class="mb-3">
                        <label for="modalUserEmail" class="form-label">To:</label>
                        <input type="text" class="form-control" id="modalUserEmail" readonly />
                    </div>

                    <div class="mb-3">
                        <label for="modalSubject" class="form-label">Subject:</label>
                        <input type="text" class="form-control" name="subject" id="modalSubject" required
                               placeholder="Email subject..." />
                    </div>

                    <div class="mb-3">
                        <label for="modalMessage" class="form-label">Message:</label>
                        <textarea class="form-control" name="message" id="modalMessage" rows="6" required
                                  placeholder="Write your message here..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send"></i> Send Email
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Populate email modal with user data
        var emailModal = document.getElementById('emailModal');
        emailModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var userId = button.getAttribute('data-user-id');
            var userName = button.getAttribute('data-user-name');
            var userEmail = button.getAttribute('data-user-email');

            document.getElementById('modalUserId').value = userId;
            document.getElementById('modalUserName').textContent = userName;
            document.getElementById('modalUserEmail').value = userEmail;
            document.getElementById('modalSubject').value = '';
            document.getElementById('modalMessage').value = '';
        });
    </script>
}
