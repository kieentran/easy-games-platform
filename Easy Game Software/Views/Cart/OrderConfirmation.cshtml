@model Easy_Games_Software.Models.Transaction
@{
    ViewData["Title"] = "Order Confirmation";
    var userTier = ViewData["UserTier"] as Easy_Games_Software.Models.UserTier?;
    var userPoints = ViewData["UserPoints"] as int? ?? 0;
}

<div class="text-center mb-4">
    <i class="bi bi-check-circle text-success" style="font-size: 80px;"></i>
    <h1 class="mt-3">Order Confirmed!</h1>
    <p class="lead">Thank you for your purchase!</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-header">
                <h5>Order Details</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Order Reference:</dt>
                    <dd class="col-sm-8"><strong>@Model.TransactionReference</strong></dd>

                    <dt class="col-sm-4">Order Date:</dt>
                    <dd class="col-sm-8">@Model.TransactionDate.ToString("MMM dd, yyyy HH:mm")</dd>

                    <dt class="col-sm-4">Item:</dt>
                    <dd class="col-sm-8">@Model.StockItem.Name</dd>

                    <dt class="col-sm-4">Quantity:</dt>
                    <dd class="col-sm-8">@Model.Quantity</dd>

                    <dt class="col-sm-4">Unit Price:</dt>
                    <dd class="col-sm-8">$@Model.UnitPrice.ToString("F2")</dd>

                    @if (Model.DiscountAmount > 0)
                    {
                        <dt class="col-sm-4">Discount:</dt>
                        <dd class="col-sm-8 text-success">-$@Model.DiscountAmount.ToString("F2")</dd>
                    }

                    <dt class="col-sm-4">Total Paid:</dt>
                    <dd class="col-sm-8"><strong class="h5">$@Model.TotalAmount.ToString("F2")</strong></dd>

                    <dt class="col-sm-4">Points Earned:</dt>
                    <dd class="col-sm-8"><span class="badge bg-info">+@Model.PointsEarned points</span></dd>
                </dl>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                <h5>Your Rewards Status</h5>
                <div class="row">
                    <div class="col-md-6">
                        <p>
                            <strong>Current Tier:</strong>
                            @if (userTier == Easy_Games_Software.Models.UserTier.Gold)
                            {
                                <span class="badge bg-warning text-dark">GOLD</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">SILVER</span>
                            }
                        </p>
                    </div>
                    <div class="col-md-6">
                        <p>
                            <strong>Total Points:</strong>
                            <span class="badge bg-primary">@userPoints</span>
                        </p>
                    </div>
                </div>

                @if (userTier == Easy_Games_Software.Models.UserTier.Silver && userPoints >= 100)
                {
                    <div class="alert alert-success">
                        <i class="bi bi-trophy"></i> Congratulations! You've been upgraded to <strong>GOLD</strong> tier!
                        Enjoy 10% off all future purchases!
                    </div>
                }
            </div>
        </div>

        <div class="text-center">
            <a asp-controller="Store" asp-action="Index" class="btn btn-primary btn-lg">
                <i class="bi bi-shop"></i> Continue Shopping
            </a>
            <a asp-controller="Account" asp-action="Profile" class="btn btn-outline-secondary btn-lg">
                <i class="bi bi-person"></i> View Profile
            </a>
        </div>
    </div>
</div>