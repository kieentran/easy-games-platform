@model Easy_Games_Software.Controllers.QuickSignupViewModel
@{
    ViewData["Title"] = "Quick Customer Signup";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0"><i class="bi bi-person-plus"></i> Quick Customer Signup</h4>
            </div>
            <div class="card-body">
                <form asp-action="QuickSignup" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label"></label>
                        <input asp-for="PhoneNumber" class="form-control form-control-lg"
                               placeholder="e.g., 0412345678" autofocus />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        <small class="form-text text-muted">
                            This will be used as the customer's username and for quick lookup.
                        </small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label"></label>
                        <input asp-for="FullName" class="form-control form-control-lg"
                               placeholder="Customer's full name" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" type="email" class="form-control"
                               placeholder="Optional email address" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i>
                        <strong>Quick Signup:</strong> A default password will be created.
                        Customer can change it later by logging into the website.
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success btn-lg">
                            <i class="bi bi-check-circle"></i> Register Customer
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Back to POS
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}