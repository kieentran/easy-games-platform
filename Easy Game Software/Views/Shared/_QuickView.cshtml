@model Easy_Games_Software.Models.StockItem

<div class="modal-header">
    <h5 class="modal-title">@Model.Name</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>
<div class="modal-body">
    <div class="row">
        <div class="col-md-4">
            <div class="text-center">
                <i class="bi bi-controller" style="font-size: 100px; color: #ccc;"></i>
            </div>
        </div>
        <div class="col-md-8">
            <p><span class="badge bg-secondary">@Model.Category</span></p>
            <p>@Model.Description</p>
            <h4>$@Model.Price.ToString("F2")</h4>
            @if (Model.IsInStock())
            {
                <span class="badge bg-success">In Stock (@Model.Quantity)</span>
            }
            else
            {
                <span class="badge bg-danger">Out of Stock</span>
            }
        </div>
    </div>
</div>
<div class="modal-footer">
    <a asp-controller="Store" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-primary">
        View Full Details
    </a>
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
</div>