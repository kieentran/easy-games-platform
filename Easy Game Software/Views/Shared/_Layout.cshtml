@* Claude Prompt 002, 003, 004, 005 - UI Layout and Navigation *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Easy Games Software</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-primary border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Store" asp-action="Index">
                    <i class="bi bi-controller"></i> Easy Games
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Store" asp-action="Index">
                                <i class="bi bi-shop"></i> Store
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Store" asp-action="Featured">
                                <i class="bi bi-star"></i> Featured
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Store" asp-action="BestSellers">
                                <i class="bi bi-trophy"></i> Best Sellers
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-light" href="#" id="categoriesDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-grid"></i> Categories
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Store" asp-action="Category" asp-route-category="Game">Games</a></li>
                                <li><a class="dropdown-item" asp-controller="Store" asp-action="Category" asp-route-category="Action">Action</a></li>
                                <li><a class="dropdown-item" asp-controller="Store" asp-action="Category" asp-route-category="RPG">RPG</a></li>
                                <li><a class="dropdown-item" asp-controller="Store" asp-action="Category" asp-route-category="Puzzle">Puzzle</a></li>
                                <li><a class="dropdown-item" asp-controller="Store" asp-action="Category" asp-route-category="Sports">Sports</a></li>
                                <li><a class="dropdown-item" asp-controller="Store" asp-action="Category" asp-route-category="Strategy">Strategy</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="Store" asp-action="Category" asp-route-category="Book">Books</a></li>
                                <li><a class="dropdown-item" asp-controller="Store" asp-action="Category" asp-route-category="Toy">Toys</a></li>
                            </ul>
                        </li>
                        @if (User.IsInRole("Owner"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-light" href="#" id="ownerDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-gear"></i> Admin
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Owner" asp-action="Index">Dashboard</a></li>
                                    <li><a class="dropdown-item" asp-controller="Owner" asp-action="Stock">Manage Stock</a></li>
                                    <li><a class="dropdown-item" asp-controller="Owner" asp-action="Users">Manage Users</a></li>
                                    <li><a class="dropdown-item" asp-controller="Owner" asp-action="Transactions">Transactions</a></li>
                                    <li><a class="dropdown-item" asp-controller="Owner" asp-action="Reports">Reports</a></li>
                                </ul>
                            </li>
                        }
                        @if (User.IsInRole("ShopProprietor"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-light" href="#" id="shopDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-shop"></i> My Shop
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="ShopInventory" asp-action="Dashboard">Dashboard</a></li>
                                    <li><a class="dropdown-item" asp-controller="PointOfSale" asp-action="Index">Point of Sale</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="ShopInventory" asp-action="ViewShopStock">View Inventory</a></li>
                                    <li><a class="dropdown-item" asp-controller="ShopInventory" asp-action="AvailableStock">Transfer Stock</a></li>
                                </ul>
                            </li>
                        }
                        @if (User.IsInRole("Owner"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="ShopManagement" asp-action="Index">
                                    <i class="bi bi-shop-window"></i> Manage Shops
                                </a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Cart" asp-action="Index">
                                    <i class="bi bi-cart3"></i> Cart
                                    <span class="badge bg-warning text-dark" id="cartCount">0</span>
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-light" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                                    @if (User.FindFirst("UserTier")?.Value == "Gold")
                                    {
                                        <span class="badge bg-warning text-dark">GOLD</span>
                                    }
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                            <i class="bi bi-person"></i> Profile
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Cart" asp-action="Index">
                                            <i class="bi bi-bag"></i> My Orders
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <span class="dropdown-item-text">
                                            <small>Points: @(User.FindFirst("UserPoints")?.Value ?? "0")</small>
                                        </span>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right"></i> Logout
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right"></i> Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Account" asp-action="Register">
                                    <i class="bi bi-person-plus"></i> Register
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["WarningMessage"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <i class="bi bi-info-circle"></i> @TempData["WarningMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light mt-5">
        <div class="container py-4">
            <div class="row">
                <div class="col-md-4">
                    <h5>Easy Games Software</h5>
                    <p>Your one-stop shop for games, books, and toys!</p>
                </div>
                <div class="col-md-4">
                    <h5>Quick Links</h5>
                    <ul class="list-unstyled">
                        <li><a href="/Store" class="text-decoration-none">Browse Store</a></li>
                        <li><a href="/Store/Featured" class="text-decoration-none">Featured Items</a></li>
                        <li><a href="/Store/BestSellers" class="text-decoration-none">Best Sellers</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h5>Rewards Program</h5>
                    <p><span class="badge bg-secondary">SILVER</span> 1 point per $10</p>
                    <p><span class="badge bg-warning text-dark">GOLD</span> 2 points per $10 + 10% discount</p>
                    <small>Upgrade to Gold at 100 points!</small>
                </div>
            </div>
            <hr />
            <div class="text-center">
                &copy; 2025 - Easy Games Software - <a asp-area="" asp-controller="Store" asp-action="Privacy">Privacy</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <script>
            // Update cart count on page load
            $(document).ready(function() {
                $.get('/Cart/GetCartCount', function(data) {
                    $('#cartCount').text(data.count);
                });
            });
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@* Claude Prompt 002, 003, 004, 005 end *@